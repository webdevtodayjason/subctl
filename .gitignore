# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Backups + archives never enter the repo
*.bak.*
*.archived-*
*.tmp
tmp/

# Orchestration scratch (multi-agent ledger + worker deliverables — local only)
.orchestration/

# Node/Bun
node_modules/
dist/
.bun/
components/mcp/bun.lockb
components/mcp/bun.lock

# Go: legacy v0.3 deck binary path (deck dropped in v0.4 in favor of sesh integration).
# Kept here so any leftover binary on upgraders' machines doesn't get accidentally tracked.
bin/subctl-deck

# subctl local config (user's real accounts.conf lives in ~/.config/subctl/, never here)
config/accounts.conf
config/accounts.conf.local

# Secrets (defensive — we never write them, but block by name)
.env
.env.*
credentials.json
.credentials.json
*.pem
*.key
# v2.7.4 — dashboard-managed API tokens. The canonical location is
# ~/.config/subctl/secrets.json (outside the repo) but block any
# accidental in-tree copy by name too.
secrets.json
.claude/worktrees/
