#!/usr/bin/env bash
# claude-dash — convenience shim for `subctl dashboard`.
# Ensures the dashboard service is running, then opens it in your browser.
# Provided by subctl (https://github.com/webdevtodayjason/subctl).
#
# Resolves the sibling v3 dispatcher in this script's bin/ directory rather
# than relying on `subctl` on PATH — v4 takes over the bare `subctl` name
# and doesn't dispatch v3 verbs.
_self="${BASH_SOURCE[0]}"
while [[ -L "$_self" ]]; do _self="$(readlink "$_self")"; done
exec "$(cd "$(dirname "$_self")" && pwd)/subctl" dashboard "$@"
