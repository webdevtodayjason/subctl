#!/usr/bin/env bash
# subctl — Subscription Central for AI subscriptions you're paying for.
# Top-level CLI dispatcher. With no args, launches the TUI menu.

set -uo pipefail

# Resolve repo root (handles being symlinked from /usr/local/bin)
_self="${BASH_SOURCE[0]}"
while [[ -L "$_self" ]]; do _self="$(readlink "$_self")"; done
SUBCTL_REPO_ROOT="$(cd "$(dirname "$_self")/.." && pwd)"
export SUBCTL_REPO_ROOT

. "$SUBCTL_REPO_ROOT/lib/core.sh"

usage() {
  cat <<EOF
subctl v$SUBCTL_VERSION — Subscription Central

Usage:
  subctl                              Launch TUI menu

  subctl accounts                     Show account status table
  subctl accounts add <provider> <alias> <email> [config_dir] [description]
  subctl accounts remove <alias> [--purge]
  subctl accounts edit                Open accounts.conf in \$EDITOR

  subctl auth <provider> <alias>      OAuth / API-key into the right config dir
                                      Providers: claude, openai, openai-codex,
                                      xai-oauth, pi-coding-agent, deepseek,
                                      gemini.
  subctl auth all                     Walk every account that needs auth

  subctl teams <provider> [opts]      tmux launcher (claude, pi-coding-agent, deepseek)
  subctl teams claude -a <alias> [-y -c -o -p TEXT -f FILE --dry-run]
  subctl teams pi-coding-agent -a <alias> [-p TEXT -f FILE -m MODEL --dry-run]
  subctl teams deepseek -a <alias> [-y -c -o -p TEXT -f FILE -m MODEL --dry-run]

  subctl radar                        /dispatch-check verdict + signals
  subctl radar log [--tail]           Inspect rate-limit events log

  subctl service status               Dashboard service state
  subctl service start                Start service (must be enabled)
  subctl service stop
  subctl service restart
  subctl service enable               Install launchd plist (auto-starts at login)
  subctl service disable              Uninstall plist
  subctl service logs [N]             Show last N log lines (default 50)
  subctl service foreground           Run dashboard in current shell

  subctl dashboard [open]             Ensure service running, open browser
  subctl dashboard deploy             Pull origin/main into install tree
                                      (~/.local/lib/subctl-install) and
                                      kickstart the daemon. Idempotent.

  subctl session-list [--format <plain|sesh|json>]
                                      List tmux sessions enriched with account
                                      + ctx % + RL today + status.
  subctl session-preview <name>       Render the metadata block for one session.
  subctl session-kill <name> [name...]
                                      Kill one or more tmux sessions.
  subctl session-prune [--older-than 6h] [--yes]
                                      Kill all tmux sessions older than DUR
                                      (default 6h). Asks before killing.
  subctl prune-transcripts [opts]     Delete OLD CLAUDE CODE TRANSCRIPT JSONLs
                                      to reclaim disk. Default: workers >30d.
                                      Flags: --older-than DUR, --all, --workers
                                      --dry-run, --archive PATH, --yes
  subctl session-resume [--cwd PATH] [--account ALIAS] [--latest] [--list]
                                      Find Claude Code sessions for a cwd
                                      across all accounts. Picker by default;
                                      --latest auto-resumes the newest;
                                      --list prints without resuming.

  subctl sessions list [--orphans|--account <alias>]
                                      List Claude session transcripts across
                                      every cfg_dir (newest first). --orphans
                                      shows sessions in default ~/.claude that
                                      no account has adopted yet.
  subctl sessions adopt <alias> <sid> [--force]
                                      Copy a session's jsonl into <alias>'s
                                      cfg_dir so 'claude-<alias> --resume <sid>'
                                      can pick it up.
  subctl sessions adopt-latest <alias> Adopt the most recent orphaned session.
  subctl sessions pick <alias>        Interactive picker (gum if installed).

  subctl projects status              Show declared projects + which are running
                                      in tmux right now.
  subctl projects start <name>        Launch one project (account-bound tmux),
                                      resuming the most recent claude session.
  subctl projects start all           Launch every project not already running.
  subctl projects edit                Open ~/.config/subctl/projects.conf.
  subctl usage [alias|all|--json]     Per-account Claude Max usage (5h, 7d,
                                      7d-Sonnet, 7d-Opus). Cached 5min.
  subctl cost [alias|all] [--window today|week|month|all] [--json]
                                      Token aggregation + API list-price cost
                                      vs subscription savings, per account.
  subctl whoami                       Current shell's CLAUDE_CONFIG_DIR account

  subctl config show [section]        Pretty-print config file content. Sections:
                                      accounts | notify | providers | policy.
                                      Secrets auto-redacted on output.
  subctl config edit [section]        Open a config file in \$EDITOR
  subctl config validate [section]    Validate JSON / TOML config files
  subctl config path                  Print accounts.conf path
  subctl doctor                       Health check
  subctl install [--migrate]          Install / re-install (file copy + symlinks)
  subctl setup                        First-run setup / reconfigure (TUI menu)
  subctl setup --wizard               Linear walk: deps → accounts → auth → service

  subctl notify <msg>                 Send Telegram message (escalation channel
                                      for orchestrators when operator is AFK).
  subctl notify --setup               Store bot token + chat id (one-time)
  subctl notify --test                Send a test message
  subctl notify --status              Show current config
  subctl notify ask-yesno|ask-choice|ask-text "<q>" --id Q42
                                      Structured Q&A — replies land in inbox.
  subctl notify inbox [--id Q42]      Read operator replies from inbox.

  subctl orch list                    List running orchestrator tmux sessions
  subctl orch spawn -a <acct> -c <path> [-o] [-y] [-p "..."] [--resume sid]
                                      Spawn a detached orchestrator session
                                      (callable from any process / ArgentOS)
  subctl orch status <name>           Live preview of one session
  subctl orch msg <name> <text>       Inject text into a session's pane
  subctl orch kill <name>             Kill a session

  subctl team list                    List active orchestrator sessions
                                      (via /api/orchestration)
  subctl team kill <name>             Kill the tmux session + archive inbox
  subctl team exec <name> <command...>
                                      Inject a one-off message (HMAC-signed)
  subctl team logs <name> [--tail N]  Tail a team's inbox JSONL
  subctl team report --team <t> --type <kind> --text "..."
                                      Append a status event to a dev-team
                                      inbox (used by team leads in dev-team
                                      tmux sessions)
  subctl team inbox <team> [--tail N] Show recent events for a team
  subctl team spawn --template <name> --project <path> [--account <alias>]
                                      v2.8.0 — spawn a multi-developer team
                                      from a TOML template
  subctl team baseline <verb> [path]  Memory Init #6 — install / inspect the
                                      claude-layers baseline (CLAUDE.md +
                                      .claude/). Verbs: init | ensure | status.

  subctl profile show                 Show active profile + supervisor
  subctl profile switch <name>        Switch active profile (chat | heavy | ...)
  subctl profile list                 List all profiles

  subctl skills import <repo>         Import a skills repo (e.g. mattpocock/skills)
                                      into the local catalog at
                                      ~/.config/subctl/skills/
  subctl skills list                  List imported skills
  subctl skills info <id>             Show one skill's frontmatter + content
  subctl skills sources               List skill sources (each imported repo)
  subctl skills router-trace <msg>    v2.8.1 — Trace which skills Evy's
                                      router would preload for a message

  subctl templates list               List dev-team templates (persona+skills+tools)
  subctl templates show <name>        Show one template's JSON
  subctl templates create <name>      Create a new template (stub or --from FILE)
  subctl templates duplicate <a> <b>  Copy a template
  subctl templates delete <name>      Remove a template

  subctl plugins list                 List installed subctl plugins
  subctl plugins install <src>        Install from git URL, owner/repo, or path
  subctl plugins remove <id>          Uninstall
  subctl plugins status               Validate all installed plugin manifests

  subctl policy <verb> [args]         Inspect / manage the policy engine for
                                      spawned coding agents (modes, allowlists,
                                      audit). Verbs: check, list, validate,
                                      explain, audit, snapshot. 'check' is the
                                      hot-path gate called by hooks; the others
                                      are operator-facing. See docs/policy.md.

  subctl update                       Pull origin/main, rebuild, restart daemons,
                                      doctor on the way out (no manual ssh+rsync)
  subctl deploy [--no-pull] [--dry-run]
                                      Fast-path deploy — git pull + launchctl
                                      kickstart -k for Evy + dashboard. See
                                      'subctl update' for the careful path.

  subctl status [--json]              One-shot health probe across Evy
                                      (:8788) + dashboard (:8787) — versions,
                                      uptime, telegram listener, profile.
  subctl logs [--master|--dashboard] [--tail N] [--follow]
                                      Tail launchd log files in
                                      ~/Library/Logs/subctl/ (Evy / dashboard;
                                      flag names stay until Phase 3 code rename).
  subctl notif [recent|list <N>|mark-all-read]
                                      Read operator notifications (Evy's ring
                                      buffer via dashboard proxy).
  subctl memory [recent <N>|search <query>|remember <text>]
                                      Query / append Evy Tier 3 memory via
                                      /api/memory/* proxy.
  subctl voice [status|test|render <text>|on|off]
                                      Voice layer (v2.8.0). status shows
                                      voice.json + TTS reachability; test
                                      renders + plays a canned line; render
                                      returns audio URL; on/off toggles
                                      voice.json#enabled (hot-reload).
  subctl prefs [show|get|set|edit|reset]
                                      Operator preferences (v2.8.1, bilateral
                                      maintenance). show lists all; get reads
                                      one; set writes one; edit opens the TOML
                                      in \$EDITOR; reset restores defaults.

  subctl uninstall                    Remove subctl
  subctl version                      Print version
  subctl help                         Show this help

Repo:    https://github.com/webdevtodayjason/subctl
License: MIT
EOF
}

# ── command dispatch ─────────────────────────────────────────────────────────
cmd="${1:-}"
[[ $# -gt 0 ]] && shift

case "$cmd" in
  ""|menu|tui)
    . "$SUBCTL_REPO_ROOT/lib/tui.sh"
    subctl_ensure_config_dir
    subctl_tui_main
    ;;

  accounts)
    . "$SUBCTL_REPO_ROOT/lib/accounts.sh"
    sub="${1:-status}"; [[ $# -gt 0 ]] && shift
    case "$sub" in
      status|list|"")  subctl_accounts_status_table ;;
      add)             subctl_accounts_add "$@" ;;
      remove|rm)       subctl_accounts_remove "$@" ;;
      edit)            subctl_accounts_edit ;;
      *) subctl_die "unknown accounts subcommand: $sub" ;;
    esac
    ;;

  auth)
    . "$SUBCTL_REPO_ROOT/lib/core.sh"
    target="${1:-}"
    case "$target" in
      all)
        . "$SUBCTL_REPO_ROOT/providers/claude/auth.sh"
        provider_claude_auth_all
        . "$SUBCTL_REPO_ROOT/providers/openai/auth.sh"
        provider_openai_auth_all
        . "$SUBCTL_REPO_ROOT/providers/openai-codex/auth.sh"
        provider_openai_codex_auth_all
        . "$SUBCTL_REPO_ROOT/providers/xai-oauth/auth.sh"
        provider_xai_oauth_auth_all
        . "$SUBCTL_REPO_ROOT/providers/pi-coding-agent/auth.sh"
        provider_pi_coding_agent_auth_all
        . "$SUBCTL_REPO_ROOT/providers/deepseek/auth.sh"
        provider_deepseek_auth_all
        ;;
      claude)
        alias="${2:-}"
        [[ -z "$alias" ]] && subctl_die "usage: subctl auth claude <alias>"
        . "$SUBCTL_REPO_ROOT/providers/claude/auth.sh"
        cfg_dir=$(subctl_account_field "$alias" 4)
        email=$(subctl_account_field "$alias" 3)
        [[ -z "$cfg_dir" ]] && subctl_die "unknown alias: $alias"
        provider_claude_auth "$alias" "$cfg_dir" "$email"
        ;;
      openai)
        alias="${2:-}"
        [[ -z "$alias" ]] && subctl_die "usage: subctl auth openai <alias>"
        . "$SUBCTL_REPO_ROOT/providers/openai/auth.sh"
        cfg_dir=$(subctl_account_field "$alias" 4)
        email=$(subctl_account_field "$alias" 3)
        [[ -z "$cfg_dir" ]] && subctl_die "unknown alias: $alias (add it first: subctl accounts add openai $alias <email>)"
        provider_openai_auth "$alias" "$cfg_dir" "$email"
        ;;
      openai-codex)
        # v2.8.9 — first-class OpenAI Codex OAuth (device-code flow in TS,
        # no external `codex` CLI dependency). See providers/openai-codex/auth.sh.
        alias="${2:-}"
        [[ -z "$alias" ]] && subctl_die "usage: subctl auth openai-codex <alias>"
        . "$SUBCTL_REPO_ROOT/providers/openai-codex/auth.sh"
        cfg_dir=$(subctl_account_field "$alias" 4)
        email=$(subctl_account_field "$alias" 3)
        [[ -z "$cfg_dir" ]] && subctl_die "unknown alias: $alias (add it first: subctl accounts add openai-codex $alias <email>)"
        provider_openai_codex_auth "$alias" "$cfg_dir" "$email"
        ;;
      xai-oauth)
        # First-class xAI Grok OAuth (SuperGrok Subscription). PKCE-loopback
        # flow in TS, no external `grok` CLI dependency. See
        # providers/xai-oauth/auth.sh.
        alias="${2:-}"
        [[ -z "$alias" ]] && subctl_die "usage: subctl auth xai-oauth <alias>"
        . "$SUBCTL_REPO_ROOT/providers/xai-oauth/auth.sh"
        cfg_dir=$(subctl_account_field "$alias" 4)
        email=$(subctl_account_field "$alias" 3)
        [[ -z "$cfg_dir" ]] && subctl_die "unknown alias: $alias (add it first: subctl accounts add xai-oauth $alias <email>)"
        provider_xai_oauth_auth "$alias" "$cfg_dir" "$email"
        ;;
      pi-coding-agent)
        alias="${2:-}"
        [[ -z "$alias" ]] && subctl_die "usage: subctl auth pi-coding-agent <alias>"
        . "$SUBCTL_REPO_ROOT/providers/pi-coding-agent/auth.sh"
        cfg_dir=$(subctl_account_field "$alias" 4)
        email=$(subctl_account_field "$alias" 3)
        [[ -z "$cfg_dir" ]] && subctl_die "unknown alias: $alias (add it first: subctl accounts add pi-coding-agent $alias <email>)"
        provider_pi_coding_agent_auth "$alias" "$cfg_dir" "$email"
        ;;
      deepseek)
        # v3.0.0-rc1 — first-class CodeWhale (codewhale; formerly DeepSeek-TUI)
        # API-key flow via codewhale's own `auth set` command inside a
        # per-alias HOME shadow. See providers/deepseek/auth.sh.
        alias="${2:-}"
        [[ -z "$alias" ]] && subctl_die "usage: subctl auth deepseek <alias>"
        . "$SUBCTL_REPO_ROOT/providers/deepseek/auth.sh"
        cfg_dir=$(subctl_account_field "$alias" 4)
        email=$(subctl_account_field "$alias" 3)
        [[ -z "$cfg_dir" ]] && subctl_die "unknown alias: $alias (add it first: subctl accounts add deepseek $alias <email>)"
        provider_deepseek_auth "$alias" "$cfg_dir" "$email"
        ;;
      gemini)
        subctl_warn "gemini provider not yet implemented (planned for v1.2 — see ROADMAP.md)"
        exit 1
        ;;
      *) subctl_die "usage: subctl auth <claude|openai|openai-codex|xai-oauth|pi-coding-agent|deepseek|gemini|all> [alias]" ;;
    esac
    ;;

  teams)
    target="${1:-}"; [[ $# -gt 0 ]] && shift
    case "$target" in
      claude)
        . "$SUBCTL_REPO_ROOT/providers/claude/teams.sh"
        provider_claude_teams "$@"
        ;;
      pi-coding-agent)
        . "$SUBCTL_REPO_ROOT/providers/pi-coding-agent/teams.sh"
        provider_pi_coding_agent_teams "$@"
        ;;
      codex|openai-codex)
        # v3.0 Phase 2: Codex CLI worker. Both `codex` and `openai-codex`
        # route here — `codex` matches the dispatcher convention
        # (`subctl teams codex -a <alias> ...`); `openai-codex` matches
        # the provider name in accounts.conf for symmetry with
        # `subctl auth openai-codex`.
        . "$SUBCTL_REPO_ROOT/providers/openai-codex/teams.sh"
        provider_openai_codex_teams "$@"
        ;;
      deepseek)
        # v3.0.0-rc1 — CodeWhale (codewhale; formerly DeepSeek-TUI) worker
        # via providers/deepseek/teams.sh. UNGATED in this RC.
        . "$SUBCTL_REPO_ROOT/providers/deepseek/teams.sh"
        provider_deepseek_teams "$@"
        ;;
      gemini|openai)
        subctl_warn "$target teams not yet implemented (phase 2/3)"
        exit 1
        ;;
      *) subctl_die "usage: subctl teams <claude|codex|deepseek|pi-coding-agent|gemini|openai> [opts]" ;;
    esac
    ;;

  radar)
    sub="${1:-verdict}"
    case "$sub" in
      verdict|"")
        bash "$SUBCTL_REPO_ROOT/providers/claude/dispatch-check.sh"
        ;;
      log)
        shift || true
        log="$HOME/.claude/rate-limit-events.log"
        if [[ "${1:-}" == "--tail" ]]; then
          [[ -f "$log" ]] && tail -f "$log" || subctl_die "no log at $log"
        else
          [[ -f "$log" ]] && tail -50 "$log" || echo "(no events)"
        fi
        ;;
      *) subctl_die "usage: subctl radar [verdict|log [--tail]]" ;;
    esac
    ;;

  service)
    . "$SUBCTL_REPO_ROOT/lib/service.sh"
    sub="${1:-status}"; [[ $# -gt 0 ]] && shift
    case "$sub" in
      status)     subctl_service_status ;;
      start)      subctl_service_start ;;
      stop)       subctl_service_stop ;;
      restart)    subctl_service_restart ;;
      enable)     subctl_service_enable ;;
      disable)    subctl_service_disable ;;
      logs)       subctl_service_logs "${1:-50}" ;;
      foreground) subctl_service_foreground ;;
      *) subctl_die "unknown service subcommand: $sub" ;;
    esac
    ;;

  dashboard)
    . "$SUBCTL_REPO_ROOT/lib/dashboard.sh"
    sub="${1:-open}"; [[ $# -gt 0 ]] && shift
    case "$sub" in
      open|"")  subctl_dashboard_open ;;
      deploy)   subctl_dashboard_deploy ;;
      *) subctl_die "usage: subctl dashboard [open|deploy]" ;;
    esac
    ;;

  deck)
    DECK_BIN="$SUBCTL_REPO_ROOT/bin/subctl-deck"
    if [[ ! -x "$DECK_BIN" ]]; then
      subctl_err "subctl-deck binary not built yet"
      subctl_err "  build:  cd $SUBCTL_REPO_ROOT/deck && go build -o $DECK_BIN ."
      subctl_err "  or re-run: subctl install"
      exit 1
    fi
    exec "$DECK_BIN" "$@"
    ;;

  session-preview)
    . "$SUBCTL_REPO_ROOT/lib/session-preview.sh"
    subctl_session_preview "$@"
    ;;

  session-list)
    . "$SUBCTL_REPO_ROOT/lib/session-preview.sh"
    subctl_session_list "$@"
    ;;

  session-kill|kill)
    . "$SUBCTL_REPO_ROOT/lib/session-preview.sh"
    subctl_session_kill "$@"
    ;;

  session-prune|prune)
    . "$SUBCTL_REPO_ROOT/lib/session-preview.sh"
    subctl_session_prune "$@"
    ;;

  prune-transcripts|transcripts-prune)
    . "$SUBCTL_REPO_ROOT/lib/session-preview.sh"
    subctl_prune_transcripts "$@"
    ;;

  session-resume|resume)
    . "$SUBCTL_REPO_ROOT/lib/session-preview.sh"
    subctl_session_resume "$@"
    ;;

  sessions)
    . "$SUBCTL_REPO_ROOT/lib/sessions.sh"
    sub="${1:-list}"; [[ $# -gt 0 ]] && shift
    case "$sub" in
      list|"")        subctl_sessions_list_table "$@" ;;
      adopt)          subctl_sessions_adopt "$@" ;;
      adopt-latest)   subctl_sessions_adopt_latest "$@" ;;
      pick)           subctl_sessions_pick "$@" ;;
      *) subctl_die "usage: subctl sessions [list|adopt <alias> <sid>|adopt-latest <alias>|pick <alias>]" ;;
    esac
    ;;

  projects)
    . "$SUBCTL_REPO_ROOT/lib/projects.sh"
    sub="${1:-status}"; [[ $# -gt 0 ]] && shift
    case "$sub" in
      status|list|"")  subctl_projects_status ;;
      start)
        target="${1:-all}"; [[ $# -gt 0 ]] && shift
        if [[ "$target" == "all" ]]; then
          subctl_projects_start_all "$@"
        else
          subctl_projects_start_one "$target" "$@"
        fi
        ;;
      edit)            subctl_projects_edit ;;
      path)            subctl_projects_path ;;
      *) subctl_die "usage: subctl projects [status|start <name|all>|edit|path]" ;;
    esac
    ;;

  usage)
    . "$SUBCTL_REPO_ROOT/lib/usage.sh"
    target="${1:-all}"
    case "$target" in
      --json)
        subctl_usage_fetch_all | jq -s .
        ;;
      all|"")
        subctl_usage_print_table
        ;;
      *)
        canonical=$(subctl_resolve_alias "$target") || subctl_die "unknown alias: $target (try: subctl accounts)"
        cfg_dir=$(subctl_account_field "$canonical" 4)
        [[ -z "$cfg_dir" ]] && subctl_die "no config_dir for $canonical"
        subctl_usage_fetch "$cfg_dir" | jq .
        ;;
    esac
    ;;

  cost)
    if ! command -v bun >/dev/null 2>&1; then
      subctl_die "bun is required for 'subctl cost' (install: curl -fsSL https://bun.sh/install | bash)"
    fi
    exec bun run "$SUBCTL_REPO_ROOT/dashboard/lib/cost.ts" "$@"
    ;;

  whoami)
    if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
      alias=$(subctl_list_accounts | awk -F'\t' -v c="$CLAUDE_CONFIG_DIR" '$4==c {print $1; exit}')
      if [[ -n "$alias" ]]; then
        printf "%s  (%s)\n" "$alias" "$CLAUDE_CONFIG_DIR"
      else
        printf "custom: %s\n" "$CLAUDE_CONFIG_DIR"
      fi
    else
      printf "default (\$HOME/.claude)\n"
    fi
    ;;

  config)
    # v2.7.36 dispatcher with secret-redacted multi-section viewer + validate.
    # Implementation lives in lib/cli.sh subctl_cli_config (got orphaned in a
    # v2.8.x merge; restored 2026-05-16). Legacy `subctl config edit` /
    # `path` still work — subctl_cli_config forwards them to the older
    # subctl_accounts_edit surface to preserve back-compat.
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_config "$@"
    ;;

  doctor)
    echo "subctl v$SUBCTL_VERSION doctor"
    echo
    printf "  Repo:           %s\n" "$SUBCTL_REPO_ROOT"
    printf "  Config dir:     %s\n" "$SUBCTL_CONFIG_DIR"
    printf "  Accounts file:  %s " "$SUBCTL_ACCOUNTS_CONF"
    [[ -f "$SUBCTL_ACCOUNTS_CONF" ]] && printf "${C_GRN}✓${C_RST}\n" || printf "${C_RED}missing${C_RST}\n"
    echo
    # Read deps from canonical manifest (lib/dep-manifest.json) — same source
    # consumed by install.sh, lib/setup.sh, dashboard /api/settings/install-checks.
    _doctor_manifest="$SUBCTL_REPO_ROOT/lib/dep-manifest.json"
    if [[ ! -f "$_doctor_manifest" ]] || ! command -v jq >/dev/null 2>&1; then
      echo "Required tools:"
      for tool in jq tmux git; do
        if command -v "$tool" >/dev/null 2>&1; then
          printf "  ${C_GRN}✓${C_RST} %-8s %s\n" "$tool" "$(command -v "$tool")"
        else
          printf "  ${C_RED}✗${C_RST} %-8s missing\n" "$tool"
        fi
      done
    else
      _doctor_detect() {
        local _id="$1" _argv _fp _rest
        _argv=$(jq -r --arg id "$_id" '.deps[] | select(.id==$id) | .detect | @sh' "$_doctor_manifest")
        eval "$_argv" >/dev/null 2>&1 && return 0
        while IFS= read -r _fp; do
          [[ -z "$_fp" ]] && continue
          eval "_fp=\"$_fp\""
          [[ -e "$_fp" ]] || continue
          _rest=$(jq -r --arg id "$_id" '.deps[] | select(.id==$id) | .detect[1:] | @sh' "$_doctor_manifest")
          eval "\"\$_fp\" $_rest" >/dev/null 2>&1 && return 0
        done < <(jq -r --arg id "$_id" '.deps[] | select(.id==$id) | .fallback_paths[]?' "$_doctor_manifest")
        return 1
      }
      echo "Hard deps (from $(basename "$_doctor_manifest")):"
      while IFS= read -r _id; do
        _name=$(jq -r --arg id "$_id" '.deps[] | select(.id==$id) | .name' "$_doctor_manifest")
        _method=$(jq -r --arg id "$_id" '.deps[] | select(.id==$id) | .install_method' "$_doctor_manifest")
        if _doctor_detect "$_id"; then
          printf "  ${C_GRN}✓${C_RST} %-22s %s\n" "$_name" "(${_method})"
        else
          printf "  ${C_RED}✗${C_RST} %-22s missing — install via: %s\n" "$_name" "$_method"
        fi
      done < <(jq -r '.deps[] | select(.tier=="hard") | .id' "$_doctor_manifest")
      echo
      echo "Soft deps:"
      while IFS= read -r _id; do
        _name=$(jq -r --arg id "$_id" '.deps[] | select(.id==$id) | .name' "$_doctor_manifest")
        _method=$(jq -r --arg id "$_id" '.deps[] | select(.id==$id) | .install_method' "$_doctor_manifest")
        if _doctor_detect "$_id"; then
          printf "  ${C_GRN}✓${C_RST} %-22s %s\n" "$_name" "(${_method})"
        else
          printf "  ${C_DIM}-${C_RST} %-22s missing (optional) — %s\n" "$_name" "$_method"
        fi
      done < <(jq -r '.deps[] | select(.tier=="soft") | .id' "$_doctor_manifest")
    fi
    echo
    echo "Claude Code integration:"
    . "$SUBCTL_REPO_ROOT/lib/settings.sh"
    while IFS= read -r cfg_dir; do
      [[ -z "$cfg_dir" ]] && continue
      printf "  ${C_DIM}%s${C_RST}\n" "$cfg_dir"
      # statusLine key in this dir's settings.json
      if [[ -f "$cfg_dir/settings.json" ]]; then
        _sl=$(jq -r '.statusLine.command // empty' "$cfg_dir/settings.json" 2>/dev/null)
        if [[ -n "$_sl" ]]; then
          printf "    ${C_GRN}✓${C_RST} statusLine → %s\n" "$_sl"
        else
          printf "    ${C_YLW}!${C_RST} settings.json has no statusLine\n"
        fi
      else
        printf "    ${C_DIM}-${C_RST} no settings.json yet\n"
      fi
      # symlinks
      for f in \
        "$cfg_dir/scripts/statusline.sh" \
        "$cfg_dir/scripts/dispatch-check.sh" \
        "$cfg_dir/hooks/log-rate-limits.sh" \
        "$cfg_dir/commands/dispatch-check.md"; do
        if [[ -L "$f" ]]; then
          target=$(readlink "$f")
          if [[ "$target" == "$SUBCTL_REPO_ROOT"/* ]]; then
            printf "    ${C_GRN}✓${C_RST} %s → repo\n" "${f#$cfg_dir/}"
          else
            printf "    ${C_YLW}!${C_RST} %s → %s (not subctl)\n" "${f#$cfg_dir/}" "$target"
          fi
        elif [[ -f "$f" ]]; then
          printf "    ${C_YLW}!${C_RST} %s (regular file, not a subctl symlink)\n" "${f#$cfg_dir/}"
        else
          printf "    ${C_DIM}-${C_RST} %s (not installed)\n" "${f#$cfg_dir/}"
        fi
      done
    done < <(subctl_settings_claude_dirs | awk '!seen[$0]++')
    echo
    echo "Service:"
    . "$SUBCTL_REPO_ROOT/lib/service.sh"
    subctl_service_status
    echo
    echo "Accounts:"
    . "$SUBCTL_REPO_ROOT/lib/accounts.sh"
    subctl_accounts_status_table

    # Per-account credential probe — verify each cfg_dir has a usable
    # OAuth bearer for the dashboard's /api/oauth/usage call. Claude Code 2.x
    # writes <cfg_dir>/.credentials.json (file-based); 1.x used Keychain
    # entries hashed by cfg_dir. Check both paths so doctor stays honest
    # across upgrade scenarios.
    echo
    echo "Credentials:"
    while IFS=$'\t' read -r alias provider email cfg_dir desc; do
      [[ "$provider" != "claude" ]] && continue
      cred_file="$cfg_dir/.credentials.json"
      hash=$(printf '%s' "$cfg_dir" | shasum -a 256 | cut -c1-8)
      svc="Claude Code-credentials-$hash"
      if [[ -r "$cred_file" ]] && jq -e '.claudeAiOauth.accessToken' "$cred_file" >/dev/null 2>&1; then
        printf "  ${C_GRN}✓${C_RST} %-20s file=%s\n" "$alias" "$cred_file"
      elif security find-generic-password -s "$svc" >/dev/null 2>&1; then
        printf "  ${C_GRN}✓${C_RST} %-20s keychain=%s ${C_DIM}(legacy 1.x)${C_RST}\n" "$alias" "$svc"
      else
        printf "  ${C_YLW}!${C_RST} %-20s ${C_DIM}(no .credentials.json at %s, no keychain fallback — re-run: subctl auth claude %s)${C_RST}\n" "$alias" "$cred_file" "$alias"
      fi
    done < <(subctl_list_accounts)

    # Usage cache freshness — when did the bash poller last write per-account?
    echo
    echo "Usage cache:"
    cache_dir="$SUBCTL_CONFIG_DIR/cache/usage"
    if [[ -d "$cache_dir" ]]; then
      now=$(date +%s)
      shopt -s nullglob
      cache_files=("$cache_dir"/*.json)
      shopt -u nullglob
      if [[ ${#cache_files[@]} -eq 0 ]]; then
        printf "  ${C_DIM}-${C_RST} no cached snapshots yet (will populate on first 'subctl usage' or dashboard refresh)\n"
      else
        for f in "${cache_files[@]}"; do
          mtime=$(stat -f %m "$f" 2>/dev/null || stat -c %Y "$f" 2>/dev/null || echo 0)
          age=$(( now - mtime ))
          name=$(basename "$f" .json)
          if (( age < 600 )); then
            printf "  ${C_GRN}✓${C_RST} %s ${C_DIM}(%ds ago)${C_RST}\n" "$name" "$age"
          else
            printf "  ${C_YLW}!${C_RST} %s ${C_DIM}(%ds ago — stale; dashboard polls every 5min)${C_RST}\n" "$name" "$age"
          fi
        done
      fi
    else
      printf "  ${C_DIM}-${C_RST} %s does not exist yet\n" "$cache_dir"
    fi

    # Utilization history — append-only file written by the dashboard's 5min poller.
    echo
    echo "Utilization history:"
    hist="$SUBCTL_CONFIG_DIR/cache/usage-history.jsonl"
    if [[ -f "$hist" ]]; then
      lines=$(wc -l < "$hist" | tr -d ' ')
      mtime=$(stat -f %m "$hist" 2>/dev/null || stat -c %Y "$hist" 2>/dev/null || echo 0)
      age=$(( $(date +%s) - mtime ))
      first_ts=$(head -1 "$hist" 2>/dev/null | jq -r '.ts // empty' 2>/dev/null || echo "")
      if (( age > 900 )); then
        printf "  ${C_YLW}!${C_RST} %s ${C_DIM}(%d entries, last write %ds ago — poller may be stalled)${C_RST}\n" "$hist" "$lines" "$age"
      else
        printf "  ${C_GRN}✓${C_RST} %s ${C_DIM}(%d entries, last write %ds ago)${C_RST}\n" "$hist" "$lines" "$age"
      fi
    else
      printf "  ${C_DIM}-${C_RST} %s not yet — start the dashboard to begin polling\n" "$hist"
    fi
    ;;

  install)
    bash "$SUBCTL_REPO_ROOT/install.sh" "$@"
    ;;

  setup)
    . "$SUBCTL_REPO_ROOT/lib/setup.sh"
    subctl_setup "$@"
    ;;

  notify)
    . "$SUBCTL_REPO_ROOT/components/notify/notify.sh"
    subctl_notify "$@"
    ;;

  orch)
    . "$SUBCTL_REPO_ROOT/components/orch/orch.sh"
    subctl_orch "$@"
    ;;

  team)
    # v2.7.36 dispatcher: list / kill / exec / logs verbs route through
    # the dashboard's /api/orchestration/* surface. report / inbox still
    # forward to the legacy components/team/team.sh helpers for
    # team-lead-from-inside-tmux usage (preserving back-compat). Got
    # orphaned in a v2.8.x merge; restored 2026-05-16.
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_team "$@"
    ;;

  profile)
    # v2.7.36 dispatcher: show / switch / list supervisor profiles.
    # Implementation in lib/cli.sh subctl_cli_profile. Got orphaned in
    # the same v2.8.x merge as `team` and `config`; restored 2026-05-16.
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_profile "$@"
    ;;

  skills)
    . "$SUBCTL_REPO_ROOT/components/skills/skills.sh"
    subctl_skills "$@"
    ;;

  templates)
    . "$SUBCTL_REPO_ROOT/components/teams/teams.sh"
    subctl_templates "$@"
    ;;

  plugins)
    . "$SUBCTL_REPO_ROOT/lib/plugins.sh"
    subctl_plugins "$@"
    ;;

  evy)
    . "$SUBCTL_REPO_ROOT/lib/evy.sh"
    subctl_evy "$@"
    ;;

  master)
    # v3.0 compat shim — `subctl master <verb>` continues to work
    # through v3.x with a deprecation warning surfaced in commit 3
    # (Phase 3). Currently routes silently to subctl_evy.
    . "$SUBCTL_REPO_ROOT/lib/evy.sh"
    subctl_evy "$@"
    ;;

  policy)
    . "$SUBCTL_REPO_ROOT/lib/policy.sh"
    _subctl_policy "$@"
    ;;

  update)
    . "$SUBCTL_REPO_ROOT/lib/update.sh"
    subctl_update "$@"
    ;;

  status)
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_status "$@"
    ;;

  logs)
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_logs "$@"
    ;;

  deploy)
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_deploy "$@"
    ;;

  notif|notifications)
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_notif "$@"
    ;;

  memory|mem)
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_memory "$@"
    ;;

  voice)
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_voice "$@"
    ;;

  memori)
    # v2.8.10 — Memori sidecar lifecycle (Memory Init #3, Phase 3b).
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_memori "$@"
    ;;

  cognee)
    # v2.8.x — Cognee sidecar lifecycle (Memory Init #1 first-class).
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_cognee "$@"
    ;;

  prefs|preferences)
    # v2.8.1 — operator preferences (bilateral maintenance).
    . "$SUBCTL_REPO_ROOT/lib/cli.sh"
    subctl_cli_prefs "$@"
    ;;

  uninstall)
    bash "$SUBCTL_REPO_ROOT/uninstall.sh" "$@"
    ;;

  version|--version|-v|-V)
    echo "subctl v$SUBCTL_VERSION"
    if (cd "$SUBCTL_REPO_ROOT" && git rev-parse --git-dir >/dev/null 2>&1); then
      _branch=$(cd "$SUBCTL_REPO_ROOT" && git rev-parse --abbrev-ref HEAD 2>/dev/null)
      _sha=$(cd "$SUBCTL_REPO_ROOT" && git rev-parse --short HEAD 2>/dev/null)
      _dirty=""
      if ! (cd "$SUBCTL_REPO_ROOT" && git diff --quiet 2>/dev/null) || \
         ! (cd "$SUBCTL_REPO_ROOT" && git diff --cached --quiet 2>/dev/null); then
        _dirty=" (dirty)"
      fi
      echo "  git: ${_branch}@${_sha}${_dirty}"
      echo "  repo: $SUBCTL_REPO_ROOT"
    fi
    ;;

  help|--help|-h)
    usage
    ;;

  *)
    subctl_err "unknown command: $cmd"
    echo
    usage
    exit 1
    ;;
esac
