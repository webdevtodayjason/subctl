{
  "_comment": "Operator-editable model routing for clawd (subctl master). Roles are semantic — model names can change without code edits. Recommendation as of 2026-05: MLX runtime on Apple Silicon, with Ollama as fallback for models without MLX ports yet.",

  "models": {
    "router": {
      "_comment": "Fast, lightweight. Used for 'is this task simple enough for me?' routing decisions and tool-call dispatch. Should fit in <8GB RAM and respond <1s.",
      "provider": "lmstudio",
      "model": "google/gemma-4-e4b",
      "host": "http://localhost:1234/v1",
      "context_length": 8192
    },
    "supervisor": {
      "_comment": "Primary thinker. Conversational chat with operator, dev-team orchestration, Telegram digests. Reasoning models (qwen3.5/3.6 a3b) need 32K+ to fit system prompt + tool schemas + transcript + thinking budget. context_length is the critical knob — master force-loads at this size at boot via /api/v1/models/load to defeat LM Studio's 4K JIT default.",
      "provider": "lmstudio",
      "model": "qwen/qwen3.6-35b-a3b",
      "host": "http://localhost:1234/v1",
      "context_length": 65536
    },
    "reviewer": {
      "_comment": "Code-strong. PR diff review, deep code reasoning. 32K is plenty for one PR + master's system block.",
      "provider": "lmstudio",
      "model": "qwen/qwen3-coder-30b",
      "host": "http://localhost:1234/v1",
      "context_length": 32768
    },
    "embeddings": {
      "_comment": "Memory + vault search. Nomic ModernBERT, fast, 768-dim. context_length omitted — embedding models don't need a forced load size.",
      "provider": "lmstudio",
      "model": "text-embedding-nomic-embed-text-v1.5",
      "host": "http://localhost:1234/v1"
    }
  },

  "escalate": {
    "_comment": "When local models aren't enough — irreversible decisions, complex multi-repo planning, hard reasoning. Verified working with argent.",
    "provider": "openai-codex",
    "model": "gpt-5.2",
    "auth": "oauth"
  },

  "fallback": {
    "_comment": "Last-resort if local stack is offline AND escalate provider is unreachable. Uses your Anthropic Max subscription via subctl's account routing.",
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "auth": "max-subscription"
  },

  "routing_policy": {
    "_comment": "Defaults applied when the master_skill doesn't override. The master can self-elevate on a per-task basis via the `escalate_decision` tool.",
    "default": "supervisor",
    "code_review": "reviewer",
    "search_memory": "embeddings",
    "irreversible_decision": "escalate",
    "multi_repo_planning": "escalate"
  },

  "memory_budget_gb": {
    "_comment": "Total resident memory the master should target on the M3 Ultra (256GB total). Helps the boot probe decide which models to keep loaded vs unload between calls. ~50GB resident is comfortable.",
    "target": 50,
    "ceiling": 80
  }
}
